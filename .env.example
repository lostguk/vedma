APP_NAME='Магазин магических товаров'
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Moscow
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === Laravel Sail Configuration ===
# Порты для локальной разработки
APP_PORT=80
FORWARD_DB_PORT=3306
FORWARD_REDIS_PORT=6379
VITE_PORT=5173

# Пользователи для Sail (автоматически устанавливаются)
WWWUSER=1000
WWWGROUP=1000

# === Database Configuration ===
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=vedma_shop
DB_USERNAME=sail
DB_PASSWORD=password

# === Session & Cache ===
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=vedma_

# === Redis Configuration ===
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

# === Mail Configuration ===
MAIL_MAILER=smtp
MAIL_HOST=smtp.mail.ru
MAIL_PORT=465
MAIL_USERNAME=your-email@mail.ru
# For gmail need add/update at https://myaccount.google.com/apppasswords
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=your-email@mail.ru
MAIL_FROM_NAME="${APP_NAME}"
MAIL_LOG_CHANNEL=daily

# === AWS Configuration ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# === Vite Configuration ===
VITE_APP_NAME="${APP_NAME}"

# === Telescope Configuration ===
TELESCOPE_ENABLED=true
TELESCOPE_DRIVER=database
TELESCOPE_PATH=telescope

# Telescope Watchers
TELESCOPE_CACHE_WATCHER=true
TELESCOPE_COMMAND_WATCHER=true
TELESCOPE_DUMP_WATCHER=true
TELESCOPE_EVENT_WATCHER=true
TELESCOPE_EXCEPTION_WATCHER=true
TELESCOPE_JOB_WATCHER=true
TELESCOPE_LOG_WATCHER=true
TELESCOPE_MAIL_WATCHER=true
TELESCOPE_MODEL_WATCHER=true
TELESCOPE_NOTIFICATION_WATCHER=true
TELESCOPE_QUERY_WATCHER=true
TELESCOPE_REDIS_WATCHER=true
TELESCOPE_REQUEST_WATCHER=true
TELESCOPE_SCHEDULE_WATCHER=true
TELESCOPE_VIEW_WATCHER=true

TELESCOPE_DB_CONNECTION=mysql

# === Alfa-Bank Payment Gateway ===
ALFABANK_BASE_URL=https://alfa.rbsuat.com
ALFABANK_USERNAME=
ALFABANK_PASSWORD=
ALFABANK_RETURN_URL=
ALFABANK_FAIL_URL=
ALFABANK_LANGUAGE=ru
ALFABANK_CURRENCY=RUB

# === Fiscalization (ATOL via Alfa-Bank) ===
ALFABANK_FISCAL_ENABLED=false
ALFABANK_FISCAL_TAX_SYSTEM=1
ALFABANK_FISCAL_TAX_TYPE=10
ALFABANK_FISCAL_PAYMENT_METHOD=4
ALFABANK_FISCAL_PAYMENT_OBJECT=1
ALFABANK_FISCAL_DELIVERY_PAYMENT_OBJECT=4
ALFABANK_FISCAL_DELIVERY_NAME=Доставка

# === Scribe Configuration ===
L5_SWAGGER_GENERATE_ALWAYS=true

# === Production Settings (for docker-compose.production.yml) ===
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://vedminozelie.ru
# FRONTEND_URL=https://vedminozelie.ru
# APP_PUBLISHED_HOST=0.0.0.0
# APP_PUBLISHED_PORT=8000
# DB_HOST=mysql
# REDIS_HOST=redis
# REDIS_PASSWORD=<set-secure-production-password>
# LOG_LEVEL=error
# TELESCOPE_ENABLED=false
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# QUEUE_CONVERSIONS_BY_DEFAULT=false
# MEDIA_LIBRARY_SESSION_AFFINITY=false
# MYSQL_VOLUME_NAME=vedma_mysql_data
# REDIS_VOLUME_NAME=vedma_redis_data
